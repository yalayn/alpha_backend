# ──────────────────────────────────────────────────────
# Variables de entorno — copia este archivo a .env
# y completa los valores reales (nunca subas .env al repo)
# ──────────────────────────────────────────────────────

# Puerto del servidor (por defecto: 3000)
PORT=3000

# Conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/project-alpha

# Secreto para firmar los JWT
JWT_SECRET=cambia_este_valor_en_produccion

# ── Cambio de Email (SPE-008) ─────────────────────────
# Base URL del frontend, usada para construir el enlace de confirmación
# que viaja en los correos. (por defecto: http://localhost:5173)
APP_BASE_URL=http://localhost:5173

# SMTP para el envío real de correos. Si SMTP_HOST queda vacío, los correos
# se simulan en el log (útil en dev). En dev se puede apuntar a Mailtrap/Ethereal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@project-alpha.local
