# ──────────────────────────────────────────────────────
# Variables de entorno — copia este archivo a .env
# y completa los valores reales (nunca subas .env al repo)
# ──────────────────────────────────────────────────────

# GitHub Personal Access Token con permiso read:contents
# Requerido por npm run sync-api para descargar el openapi.yaml
# desde alpha_ia_spec (repo privado)
# Genera uno en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
